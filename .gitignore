# Python 缓存
__pycache__/
*.py[cod]
*$py.class

# 数据文件夹管理：忽略所有文件，但允许遍历子目录并跟踪指定的标注/元数据文件
data/**
!data/**/

# 允许保存的数据/标注及元数据文件类型
!data/**/*.txt
!data/**/*.xml
!data/**/*.csv
!data/**/*.md
!data/**/*.yaml
!data/**/*.json

# 忽略所有图像（全局规则）
*.jpg
*.jpeg
*.png
*.bmp
*.webp
*.gif

# 忽略压缩文件与缓存
data/**/*.7z
data/**/*.zip
data/**/*.tar.gz
data/**/*.rar
data/**/*.cache
data/**/ultralytics_config/

# 忽略 GitNexus 相关文件
.gitnexus/


# 忽略输出文件夹 (包含推理渲染图、检测报告及被过滤的非合规图片)
outputs/
server_outputs/

# 忽略临时脚本文件夹
scratch/

# 忽略权重文件和缓存文件
*.pt
*.onnx
*.engine
src/yolov8n.pt
src/runs/

# 忽略通用输出格式和日志
.system_generated/
*.csv
*.xlsx
*.log

# 忽略压缩文件与IDE临时文件
*.zip
*.tar.gz
*.rar
.idea/
.vscode/
.gemini/
*.DS_Store
.DS_Store
.pytest_cache/

# Keep YOLO stage 3 annotation metadata traceable even though generic CSV files are ignored.
!data/yolo_stage3_manual/annotation_registry.csv
!data/yolo_stage3_manual/selection_manifest.csv
!data/yolo_stage3_manual/**/selection_manifest.csv
