# Python 缓存
__pycache__/
*.py[cod]
*$py.class

# 忽略数据文件夹 (包含所有大型原图、标注及临时YOLO数据集)
data/
!data/
!data/yolo_stage3_manual/
!data/yolo_stage3_manual/README.md
!data/yolo_stage3_manual/annotation_registry.csv
!data/yolo_stage3_manual/selection_manifest.csv
!data/yolo_stage3_manual/batches/
!data/yolo_stage3_manual/batches/**
!data/yolo_stage3_manual/candidate_images/
!data/yolo_stage3_manual/candidate_images/**
!data/yolo_stage3_manual/labelimg_work/
!data/yolo_stage3_manual/labelimg_work/**
!data/yolo_stage3_manual/review/
!data/yolo_stage3_manual/review/**
data/yolo_stage3_manual/dataset/
data/yolo_stage3_manual/exports/
data/yolo_stage3_manual/ultralytics_config/
data/yolo_stage3_manual/**/*.cache

# 忽略输出文件夹 (包含推理渲染图、检测报告及被过滤的非合规图片)
outputs/
server_outputs/

# 忽略临时脚本文件夹
scratch/

# 忽略权重文件和缓存文件
*.pt
*.onnx
*.engine
src/yolov8n.pt
src/runs/

# 忽略通用输出格式和日志
.system_generated/
*.csv
*.xlsx
*.log

# 忽略压缩文件与IDE临时文件
*.zip
*.tar.gz
*.rar
.idea/
.vscode/
.gemini/
